{
  "name": "attendance-api",
  "version": "2.0.0",
  "description": "Attendance management API server",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "check": "biome check --write .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@scalar/fastify-api-reference": "^1.25.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
